      "function_name": "OrderStatus",
      "module": "Strategy",
      "description": "订单状态",
      "signature": "class OrderStatus(Enum):\n    # 订单新创建未委托，用于盘前/隔夜单，订单在开盘时变为 open 状态开始撮合\n    new = 8\n\n    # 订单未完成, 无任何成交\n    open = 0\n\n    # 订单未完成, 部分成交\n    filled = 1\n\n    # 订单完成, 已撤销, 可能有成交, 需要看 Order.filled 字段\n    canceled = 2\n\n    # 订单完成, 交易所已拒绝, 可能有成交, 需要看 Order.filled 字段\n    rejected = 3\n\n    # 订单完成, 全部成交, Order.filled 等于 Order.amount\n    held = 4",
