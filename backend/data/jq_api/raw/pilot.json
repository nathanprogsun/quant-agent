      "params": [
        {"name": "open_commission", "type": "float", "default": "-", "description": "买入佣金率"},
        {"name": "close_commission", "type": "float", "default": "-", "description": "卖出佣金率"},
        {"name": "min_commission", "type": "float", "default": "-", "description": "最低佣金"}
