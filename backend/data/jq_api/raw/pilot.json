{
  "version": "pilot-2026-06-24",
  "source": "joinquant.com/help/api/help",
  "functions": [
    {
      "function_name": "get_price",
      "module": "Stock",
      "signature": "get_price(security, start_date=None, end_date=None, frequency='daily', fields=None, skip_paused=False, fq='pre')",
      "params": [
        {"name": "security", "type": "str/list", "default": "-", "description": "股票代码或代码列表"},
        {"name": "frequency", "type": "str", "default": "daily", "description": "频率: daily/1m/5m/60m 等"},
        {"name": "fields", "type": "list", "default": "None", "description": "字段列表如 open close high low volume"}
      ],
      "returns": "pandas DataFrame, 列为 fields 指定字段",
      "examples": ["df = get_price('000001.XSHE', start_date='2024-01-01', end_date='2024-01-31')"],
      "notes": "获取行情数据 ♠ 研究/回测/模拟可用",
      "env_text": "研究 回测 模拟"
    },
    {
      "function_name": "order_target",
      "module": "Trading",
      "signature": "order_target(security, amount)",
      "params": [
        {"name": "security", "type": "str", "default": "-", "description": "标的代码"},
        {"name": "amount", "type": "int", "default": "-", "description": "目标持仓股数"}
      ],
      "returns": "Order 对象或 None",
      "examples": ["order_target('000001.XSHE', 1000)"],
      "notes": "调整持仓到目标股数 ♠ 回测/模拟",
      "env_text": "回测 模拟"
    },
    {
      "function_name": "order_value",
      "module": "Trading",
      "signature": "order_value(security, value)",
      "params": [
        {"name": "security", "type": "str", "default": "-", "description": "标的代码"},
        {"name": "value", "type": "float", "default": "-", "description": "目标持仓市值"}
      ],
      "returns": "Order 对象或 None",
      "examples": ["order_value('000001.XSHE', 10000)"],
      "notes": "按目标市值下单 ♠ 回测/模拟",
      "env_text": "回测 模拟"
    },
    {
      "function_name": "order",
      "module": "Trading",
      "signature": "order(security, amount, style=None)",
      "params": [
        {"name": "security", "type": "str", "default": "-", "description": "标的代码"},
        {"name": "amount", "type": "int", "default": "-", "description": "正数买入负数卖出"},
        {"name": "style", "type": "MarketOrderStyle/LimitOrderStyle", "default": "None", "description": "订单类型"}
      ],
      "returns": "Order 对象",
      "examples": ["order('000001.XSHE', 100)"],
      "notes": "按股数下单 ♠ 回测/模拟",
      "env_text": "回测 模拟"
    },
    {
      "function_name": "get_fundamentals",
      "module": "Stock",
      "signature": "get_fundamentals(query, date=None, statDate=None)",
      "params": [
        {"name": "query", "type": "Query", "default": "-", "description": "fundamentals 查询对象"},
        {"name": "date", "type": "str", "default": "None", "description": "查询日期"}
      ],
      "returns": "pandas DataFrame 财务/估值数据",
      "examples": ["q = query(valuation.code, valuation.pe_ratio).filter(valuation.pe_ratio < 20)"],
      "notes": "查询财务基本面数据 ♠ 研究/回测",
      "env_text": "研究 回测"
    },
    {
      "function_name": "get_index_stocks",
      "module": "index",
      "signature": "get_index_stocks(index_symbol, date=None)",
      "params": [
        {"name": "index_symbol", "type": "str", "default": "-", "description": "指数代码如 000300.XSHG"},
        {"name": "date", "type": "str", "default": "None", "description": "成分股日期"}
      ],
      "returns": "股票代码列表",
