    },
    {
      "function_name": "history",
      "module": "Stock",
      "signature": "history(count, unit='1d', field='avg', security_list=None, df=True, skip_paused=False, fq='pre')",
      "params": [
        {"name": "count", "type": "int", "default": "-", "description": "bar 数量"},
        {"name": "unit", "type": "str", "default": "1d", "description": "时间单位"},
        {"name": "field", "type": "str", "default": "avg", "description": "字段名"},
        {"name": "security_list", "type": "list", "default": "None", "description": "标的列表,默认当前股票池"}
      ],
      "returns": "DataFrame 或 dict 历史数据",
      "examples": ["history(20, field='close')"],
      "notes": "批量获取历史行情 ♠ 回测",
      "env_text": "回测"
    },
    {
      "function_name": "attribute_history",
      "module": "Stock",
      "signature": "attribute_history(security, count, unit='1d', fields=['open','close'], skip_paused=True, df=True, fq='pre')",
      "params": [
        {"name": "security", "type": "str", "default": "-", "description": "单个标的"},
        {"name": "count", "type": "int", "default": "-", "description": "bar 数"},
        {"name": "fields", "type": "list", "default": "open close", "description": "字段列表"}
      ],
      "returns": "DataFrame 历史数据",
      "examples": ["attribute_history('000001.XSHE', 30, fields=['close'])"],
      "notes": "单标的 attribute 历史数据 ♠ 回测",
      "env_text": "回测"
    },
