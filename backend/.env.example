# JWT Configuration
JWT_SECRET_KEY="replace-with-random-64-char-string"
JWT_ALGORITHM="HS256"
JWT_EXPIRE_MINUTES=10080

# Application Settings
APP_NAME="quant-agent-backend"
ENVIRONMENT="local"
DEBUG="true"
LOG_LEVEL="INFO"

# Database
DATABASE_URL="sqlite+aiosqlite:///./data.db"
DB_BACKEND="sqlite"

# CORS
CORS_ALLOW_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# OpenAI API (MiniMax compatible)
OPENAI_API_KEY=your-mini-max-api-key
OPENAI_BASE_URL="https://api.minimaxi.com/v1"
MODEL="MiniMax-M3"

# OpenAI Embedding (OpenRouter)
OPENAI_EMBEDDING_BASE_URL=https://openrouter.ai/api/v1
OPENAI_EMBEDDING_API_KEY=your-openrouter-api-key
OPENAI_EMBEDDING_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free

# OpenAI Rerank (OpenRouter)
OPENAI_RERANK_BASE_URL=https://openrouter.ai/api/v1/rerank
OPENAI_RERANK_API_KEY=your-openrouter-api-key
OPENAI_RERANK_MODEL=nvidia/llama-nemotron-rerank-vl-1b-v2:free
