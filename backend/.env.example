# Application
APP_NAME="backend"
ENVIRONMENT="local"
DEBUG=true

# Database
DATABASE_URL="sqlite+aiosqlite:///./data.db"
DB_ECHO=false

# Redis (optional)
# REDIS_HOST="localhost"
# REDIS_PORT=6379
# REDIS_USER=""
# REDIS_PASS=""
# REDIS_DB=0

# JWT
JWT_SECRET_KEY="changeme-in-production"
JWT_ALGORITHM="HS256"
JWT_EXPIRE_MINUTES=10080
JWT_ISSUER="http://localhost"
JWT_AUDIENCE="http://localhost"

# Session
# import secrets; print(secrets.token_urlsafe(64))
SESSION_SECRET_KEY="changeme-in-production"

# Logging
LOG_LEVEL="INFO"

# CORS
CORS_ALLOW_ORIGINS='["http://localhost:3000","http://localhost:8000"]'
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS='["*"]'
CORS_ALLOW_HEADERS='["*"]'

# OpenTelemetry (optional)
# OPENTELEMETRY_ENDPOINT=""
# OPENTELEMETRY_SERVICE_NAME="backend"

# Sentry (optional)
# SENTRY_DSN=""
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_PROFILES_SAMPLE_RATE=0.1

# Datadog (optional)
# DATADOG_ON=false
# DATADOG_AGENT_HOST="localhost"
# DATADOG_AGENT_PORT=8125
